# Django & Security
# Secret key for session encryption and CSRF tokens
# Generate a new one: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=my-secret-key  # pragma: allowlist secret

# Debug mode (set to False in production)
DEBUG=True

# Database connection
# Format: postgres://username:password@host:port/database # pragma: allowlist secret
# Default local: postgres://cosqua:cosqua@localhost:5432/cosqua # pragma: allowlist secret
DATABASE_URL=postgres://cosqua:cosqua@localhost:5432/cosqua  # pragma: allowlist secret

# Email configuration
# The default email address for system notifications and outgoing emails
DEFAULT_FROM_EMAIL=noreply@example.com

# SMTP Email Backend (optional - uncomment to enable)
# If these are not set, Django will use console backend in development
# EMAIL_HOST=smtp.gmail.com           # e.g., smtp.gmail.com
# EMAIL_PORT=587                      # Usually 587 for TLS or 465 for SSL
# EMAIL_USE_TLS=True                  # True for TLS, False for SSL
# EMAIL_HOST_USER=your-email@example.com
# EMAIL_HOST_PASSWORD=your-app-password  # pragma: allowlist secret

# Social Authentication (GitHub - optional)
# Required for GitHub login via django-allauth
# Get credentials from: https://github.com/settings/developers
GITHUB_CLIENT_ID=my-github-client-id  # pragma: allowlist secret
GITHUB_SECRET=my-github-secret  # pragma: allowlist secret

# AI/ML Services
# Anthropic API Key for Claude-powered audit features
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here  # pragma: allowlist secret

# Anthropic Model identifier
# Use latest stable: anthropic:claude-sonnet-4-0 or check https://docs.anthropic.com/en/docs/models
ANTHROPIC_MODEL=anthropic:claude-sonnet-4-0
